# Configuration reference: https://docs.postqueen.ai/configuration/reference

# === Required Settings
DATABASE_URL="postgresql://postqueen-user:postqueen-password@localhost:5432/postqueen-db-local"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="random string for your JWT secret, make it long"
# Key for data encrypted at rest: integration OAuth and refresh tokens, provider
# credentials, stored cookies. Keep it SEPARATE from JWT_SECRET — they used to be
# the same value, which meant rotating the signing key silently made every
# connected social account undecryptable. Falls back to JWT_SECRET when unset, so
# an existing install keeps working; set it before you have real data.
# ENCRYPTION_KEY=""
# The key this data was encrypted under BEFORE the current one. Set this to the
# old value whenever you change ENCRYPTION_KEY — or before rotating JWT_SECRET
# on an install that predates ENCRYPTION_KEY — otherwise rows nothing happens to
# rewrite become permanently unreadable. Remove it once everything has been
# re-encrypted under the current key.
# PREVIOUS_ENCRYPTION_KEY=""

# Apply the schema with `prisma migrate deploy` instead of `db push`. Leave unset
# and startup behaves exactly as before. `db push --accept-data-loss` reconciles
# whatever the schema says on every boot, which is convenient for development and
# unforgiving with real data; migrations give you a reviewable, ordered history.
# To switch an existing database over, baseline it once:
#   prisma migrate resolve --applied 0_init
# Unset, empty, "false" or "0" keeps db push; any other value uses migrations,
# so a typo errs toward the non-destructive path.
# PRISMA_MIGRATE=true

# === This needs to be exactly the URL you're accessing PostQueen on
FRONTEND_URL="http://localhost:4200"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="http://localhost:3000"

## Remember to set your public internet IP address in the allow-list for the API token.
##
## Cloudflare is currently required to save things like social media avatars for accounts.
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_ACCESS_KEY="your-access-key"
CLOUDFLARE_SECRET_ACCESS_KEY="your-secret-access-key"
CLOUDFLARE_BUCKETNAME="your-bucket-name"
CLOUDFLARE_BUCKET_URL="https://your-bucket-url.r2.cloudflarestorage.com/"
CLOUDFLARE_REGION="auto"

# === Common optional Settings

## Email. EMAIL_PROVIDER must be set explicitly to "resend" or "nodemailer";
## any other value — including leaving it unset — silently selects a provider
## that sends nothing, and password resets then report success while no mail
## goes out. Without a working provider, passwordless login is unavailable and
## new accounts are activated without email verification.
#EMAIL_PROVIDER="resend"
## Resend: create your own key, the value below is a placeholder.
#RESEND_API_KEY="re_your_key_here"
#EMAIL_FROM_ADDRESS=""
#EMAIL_FROM_NAME=""
## Nodemailer instead of Resend:
#EMAIL_HOST=""
#EMAIL_PORT=""
#EMAIL_SECURE="true"
#EMAIL_USER=""
#EMAIL_PASS=""
#DISABLE_REGISTRATION=false

# Where will social media icons be saved - local or cloudflare.
STORAGE_PROVIDER="local"

# Your upload directory path if you host your files locally, otherwise Cloudflare will be used.
#UPLOAD_DIRECTORY=""

# Your upload directory path if you host your files locally, otherwise Cloudflare will be used.
#NEXT_PUBLIC_UPLOAD_STATIC_DIRECTORY=""

# Social Media API Settings
X_URL=""
X_API_KEY=""
X_API_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
BEEHIIVE_API_KEY=""
BEEHIIVE_PUBLICATION_ID=""
LISTMONK_DOMAIN=""
LISTMONK_USER=""
LISTMONK_API_KEY=""
LISTMONK_LIST_ID=""
THREADS_APP_ID=""
THREADS_APP_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
DRIBBBLE_CLIENT_ID=""
DRIBBBLE_CLIENT_SECRET=""
TUMBLR_CLIENT_ID=""
TUMBLR_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN_ID=""
SLACK_ID=""
SLACK_SECRET=""
SLACK_SIGNING_SECRET=""
MASTODON_URL="https://mastodon.social"
MASTODON_CLIENT_ID=""
MASTODON_CLIENT_SECRET=""

# Chrome Extension Settings (for cookie-based platform integrations like Skool)
EXTENSION_ID=""

# Misc Settings
OPENAI_API_KEY=""
NEXT_PUBLIC_POLOTNO=""
# Set to "true" ONLY for local HTTP development: it drops secure/httpOnly/
# sameSite from the auth cookie. Any other value (including "false") keeps the
# cookie protected.
# NOT_SECURED=true
API_LIMIT=30 # The limit of the public API hour limit

# When connecting providers that take a self-hosted URL (WordPress, Mastodon,
# Lemmy, Listmonk, Bluesky PDS, etc.) PostQueen fetches that URL server-side and
# blocks requests that resolve to private/internal/loopback/link-local IPs to
# prevent SSRF. Set to true ONLY if your PostQueen instance must reach those
# services on a trusted private network (e.g. same Docker network or VPC).
# DISABLE_SSRF_PROTECTION=false

# Payment settings
FEE_AMOUNT=0.05
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_SIGNING_KEY=""
STRIPE_SIGNING_KEY_CONNECT=""

# === Passwordless login + security (all optional) ===
# Passwordless email-code (OTP) login. Leave unset to keep the standard
# email+password + OAuth login (default). Requires an EMAIL_PROVIDER so the
# codes can be delivered.
# PASSWORDLESS_LOGIN=true

# Cloudflare Turnstile. BOTH keys are needed for the captcha to mean anything:
# the site key renders the widget, the secret key is what actually verifies the
# answer. Setting only the site key gives you a widget nobody checks.
# TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET=""

# Abuse limits for the passwordless login endpoints. These are on by default
# and need no configuration; the values below are the defaults. Set a limit to
# 0 to switch that dimension off.
# GUARD_WINDOW_MS=900000
# GUARD_OTP_REQUEST_EMAIL=5
# GUARD_OTP_REQUEST_IP=30
# GUARD_OTP_VERIFY_EMAIL=10
# GUARD_OTP_VERIFY_IP=60
# GUARD_LOGIN_EMAIL=20
# GUARD_LOGIN_IP=60
# GUARD_REGISTER_EMAIL=5
# GUARD_REGISTER_IP=20
# GUARD_FORGOT_EMAIL=5
# GUARD_FORGOT_IP=20
# Which actions require a captcha when TURNSTILE_SECRET is set.
# GUARD_CAPTCHA_ACTIONS="otp_request"
#
# Limits are shared across backend instances when REDIS_URL is set; without it
# each process counts on its own.

# Developer Settings
NX_ADD_PLUGINS=false
IS_GENERAL="true" # required for now
NEXT_PUBLIC_POSTQUEEN_OAUTH_DISPLAY_NAME="Authentik"
NEXT_PUBLIC_POSTQUEEN_OAUTH_LOGO_URL="https://raw.githubusercontent.com/walkxcode/dashboard-icons/master/png/authentik.png"
POSTQUEEN_GENERIC_OAUTH="false"
POSTQUEEN_OAUTH_URL="https://auth.example.com"
POSTQUEEN_OAUTH_AUTH_URL="https://auth.example.com/application/o/authorize"
POSTQUEEN_OAUTH_TOKEN_URL="https://auth.example.com/application/o/token"
POSTQUEEN_OAUTH_USERINFO_URL="https://authentik.example.com/application/o/userinfo"
POSTQUEEN_OAUTH_CLIENT_ID=""
POSTQUEEN_OAUTH_CLIENT_SECRET=""

# Short Link Service Settings
# DUB_TOKEN="" # Your self-hosted Dub API token
# DUB_API_ENDPOINT="https://api.dub.co" # Your self-hosted Dub API endpoint
# DUB_SHORT_LINK_DOMAIN="dub.sh" # Your self-hosted Dub domain

# SHORT_IO_SECRET_KEY="" # Your Short.io API secret key

# KUTT_API_KEY="" # Your Kutt.it API key
# KUTT_API_ENDPOINT="https://kutt.it/api/v2" # Your self-hosted Kutt API endpoint
# KUTT_SHORT_LINK_DOMAIN="kutt.it" # Your self-hosted Kutt domain

# LINK_DRIP_API_KEY="" # Your LinkDrip API key
# LINK_DRIP_API_ENDPOINT="https://api.linkdrip.com/v1/" # Your self-hosted LinkDrip API endpoint
# LINK_DRIP_SHORT_LINK_DOMAIN="dripl.ink" # Your self-hosted LinkDrip domain

# === Deployment identity (leave unset for a single-host install)
## Where your Terms and Privacy pages live, if they are not served by this app.
#LEGAL_URL="https://example.com"
## Who reviews new agency signups. Unset means nobody is notified.
#AGENCY_NOTIFICATION_EMAIL=""
## Your own affiliate programme, if you run one. Unset hides the menu entry.
#AFFILIATE_URL=""
## Your own Chrome Web Store listing, if you publish a build of the extension.
## Unset hides the install prompts — the upstream build only talks to its own
## domain, so pointing your users at it would hand them something that cannot work.
#EXTENSION_STORE_URL=""
## Your own onboarding/tutorial video. Unset hides the player rather than
## showing your users somebody else's video.
#ONBOARDING_VIDEO_URL=""
## Where your source code is published. AGPL asks you to offer the source of
## *your* modified version, so this should point at your fork, not upstream.
## Unset drops the link from the FAQ.
#REPOSITORY_URL=""
## Chatbase support widget: the token signs an SSO session for one specific bot,
## so both must be yours.
#CHATBASE_BOT_ID=""

# === Analytics (each loads only when its own key is set)
## Plausible: unset means the script is never loaded.
#PLAUSIBLE_DOMAIN=""
## Dub.co click tracking. Loads a third-party script and sets cookies, so it
## stays off until you configure it.
#DUB_PUBLISHABLE_KEY=""
## Meta pixel. When set, `pnpm install` downloads fbevents.js into
## apps/frontend/public/f.js; unset, nothing is downloaded and no pixel loads.
#NEXT_PUBLIC_FACEBOOK_PIXEL=""
